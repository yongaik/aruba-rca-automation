# ── UXI ──────────────────────────────────────────────
UXI_API_TOKEN=your_uxi_bearer_token_here
UXI_BASE_URL=https://api.capenetworks.com

# ── Aruba Central (HPE GreenLake integrated) ──────────
CENTRAL_CLIENT_ID=your_central_client_id
CENTRAL_CLIENT_SECRET=your_central_client_secret
CENTRAL_BASE_URL=https://au1.api.central.arubanetworks.com
# Region base URLs:
#   Australia:      https://au1.api.central.arubanetworks.com
#   APAC/Singapore: https://in1.api.central.arubanetworks.com
#   Japan:          https://jp1.api.central.arubanetworks.com
#   US:             https://us1.api.central.arubanetworks.com
#   EU:             https://de1.api.central.arubanetworks.com
#
# Credentials: In Central → Account Home → API Gateway → Create API Client
# Token URL defaults to https://sso.common.cloud.hpe.com/as/token.oauth2
# (works for both Central-native and GreenLake Personal API Clients)
# CENTRAL_TOKEN_URL=https://sso.common.cloud.hpe.com/as/token.oauth2  # optional override
#
# GreenLake workspace UUID — only needed for GLP Personal API Client tokens
# CENTRAL_WORKSPACE_ID=your_glp_workspace_uuid

# ── ClearPass CPPM ────────────────────────────────────
CPPM_HOST=https://your-clearpass-fqdn-or-ip
CPPM_CLIENT_ID=your_cppm_api_client_id
CPPM_CLIENT_SECRET=your_cppm_api_client_secret

# ── Anthropic Claude ──────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Slack ─────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
SLACK_CHANNEL=#network-alerts     # optional, depends on webhook config

# Slack Socket Mode listener (python main.py slack-listen)
SLACK_APP_TOKEN=xapp-...          # App-level token — api.slack.com/apps > Socket Mode
SLACK_BOT_TOKEN=xoxb-...          # Bot token — requires channels:history scope
SLACK_LISTEN_CHANNEL=#all-g5shop  # Channel ID (C...) or name to watch for UXI alerts
SLACK_RCA_COOLDOWN_SECONDS=120    # Min seconds between RCA runs (prevents duplicate triggers)

# ── Scheduler ─────────────────────────────────────────
POLL_INTERVAL_MINUTES=10
WEBHOOK_PORT=5001
